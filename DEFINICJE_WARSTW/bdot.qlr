          <rule label="transportu i łączności" key="{d49eb8a6-df01-4e79-9b14-ccc9780beecb}" symbol="9" filter="KODKST = '102'"/>
          <rule label="zbiorniki, silosy i budynki magazynowe" key="{e9787387-bb67-4010-a26f-1c3349e406e9}" symbol="10" filter="KODKST = '104'"/>
          <rule label="pozostałe niemieszkalne" key="{b270a1dc-c695-4c24-b026-c3ae1d5fb0f0}" symbol="11" filter="KODKST = '109'"/>
