          <rule key="{939d3f22-32be-474c-96e2-e075553601a5}" symbol="1" filter="KODKST = '110' and (PRZEWAZAJACAFUNKCJABUDYNKU != 'budynek jednorodzinny' and PRZEWAZAJACAFUNKCJABUDYNKU != 'dom opieki społecznej' and PRZEWAZAJACAFUNKCJABUDYNKU != 'dom letniskowy')" label="BUDYNKI MIESZKALNE WIELORODZINNE I ZAMIESZKANIA ZBIOROWEGO"/>
