          <rule symbol="1" label="Zabudowa handlowo‐usługowa" key="{bd82ff0f-b02c-4d5f-930f-7db9dc85e5e9}" filter=" &quot;RODZAJ&quot;  = 'handlowo-usługowa' "/>
          <rule symbol="2" label="Zabudowa przemysłowo-składowa" key="{ecc45c64-30d4-4939-8953-cef4eb3065b7}" filter="&quot;RODZAJ&quot;  =  'przemysłowo-składowa'"/>
          <rule symbol="3" label="Pozostała zabudowa" key="{357c8479-529a-43eb-ac6f-361ca5fef306}" filter=" &quot;RODZAJ&quot;  =  'pozostała zabudowa' "/>
          <rule symbol="4" label="Pozostałe tereny niezabudowane" key="{40eabcde-e1e7-47db-a6cf-af5adbd06bb3}" filter=" &quot;RODZAJ&quot;  = 'teren przemysłowo-składowy' or  &quot;RODZAJ&quot;  =  'teren pod urządzeniami technicznymi lub budowlami' or &quot;RODZAJ&quot;  =  'plac' "/>
          <rule symbol="5" label="Tereny komunikacyjne" key="{66f6bff7-5a67-4172-bfd2-3acb74b8e1e2}" filter=" &quot;RODZAJ&quot;  =  'teren komunikacyjny' "/>
          <rule symbol="6" label="Wyrobiska lub zwałowiska" key="{43ac9ded-9323-4f7a-9db6-b83145d86a6e}" filter=" &quot;RODZAJ&quot;  =  'wyrobisko'  OR &quot;RODZAJ&quot;  =  'zwałowisko' "/>
          <rule symbol="7" label="Składowiska odpadów" key="{324e05ec-bb92-4763-b482-91ed5a237c74}" filter=" &quot;RODZAJ&quot;  =  'odpady komunalne' or &quot;RODZAJ&quot;  =  'odpady przemysłowe' "/>
          <rule symbol="8" label="Grunty nieużytkowane" key="{d0a9d586-55ac-4d76-929f-5677f7ce5483}" filter="&quot;RODZAJ&quot;  =  'pozostałe grunty nieużytkowane' or  &quot;RODZAJ&quot;  =  'piarg, usypisko lub rumowisko skalne' or  &quot;RODZAJ&quot;  = 'teren kamienisty'  or  &quot;RODZAJ&quot;  =  'teren piaszczysty lub żwirowy'"/>
          <rule symbol="9" label="Uprawy trwałe" key="{2c0ae599-d3a2-4d7f-a0ae-5c1da88de561}" filter="&quot;RODZAJ&quot;  = 'ogródki działkowe' or  &quot;RODZAJ&quot;  =  'plantacja' or &quot;RODZAJ&quot;  =  'sad' or  &quot;RODZAJ&quot;  =  'szkółka roślin'"/>
          <rule symbol="10" label="Teren leśny i zadrzewiony" key="{c1a17dc0-3604-4416-9e33-49e56a104c74}" filter="&quot;RODZAJ&quot;  =  'las' or &quot;RODZAJ&quot;  =  'zagajnik' or  &quot;RODZAJ&quot;  =  'zadrzewienie'"/>
          <rule symbol="11" label="Roślinność trawiasta lub krzewiasta" key="{3a0b42d5-fb51-401e-9efa-4b61705a6751}" filter="&quot;RODZAJ&quot;  =  'kosodrzewina' or &quot;RODZAJ&quot;  =  'krzewy' or &quot;RODZAJ&quot;  =  'roślinność trawiasta'"/>
          <rule symbol="12" label="Uprawy na gruntach ornych" key="{8a5bba97-e6db-460e-8d45-b187c1f8cb89}" filter="&quot;RODZAJ&quot;  =  'uprawa na gruntach ornych' "/>
          <rule symbol="13" label="Wody powierzchniowe" key="{29b781b6-3791-40fa-a0be-061bbf116792}" filter="&quot;RODZAJ&quot;  =  'woda płynąca' or &quot;RODZAJ&quot;  =  'woda stojąca' or &quot;RODZAJ&quot;  =  'woda morska'"/>
