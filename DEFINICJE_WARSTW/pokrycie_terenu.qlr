          <rule key="{40eabcde-e1e7-47db-a6cf-af5adbd06bb3}" symbol="4" label="Pozostałe tereny niezabudowane" filter=" &quot;RODZAJ&quot;  = 'teren przemysłowo-składowy' or  &quot;RODZAJ&quot;  =  'teren pod urządzeniami technicznymi lub budowlami' or &quot;RODZAJ&quot;  =  'plac' "/>
          <rule key="{66f6bff7-5a67-4172-bfd2-3acb74b8e1e2}" symbol="5" label="Tereny komunikacyjne" filter=" &quot;RODZAJ&quot;  =  'teren komunikacyjny' "/>
          <rule key="{43ac9ded-9323-4f7a-9db6-b83145d86a6e}" symbol="6" label="Wyrobiska lub zwałowiska" filter=" &quot;RODZAJ&quot;  =  'wyrobisko'  OR &quot;RODZAJ&quot;  =  'zwałowisko' "/>
          <rule key="{324e05ec-bb92-4763-b482-91ed5a237c74}" symbol="7" label="Składowiska odpadów" filter=" &quot;RODZAJ&quot;  =  'odpady komunalne' or &quot;RODZAJ&quot;  =  'odpady przemysłowe' "/>
          <rule key="{d0a9d586-55ac-4d76-929f-5677f7ce5483}" symbol="8" label="Grunty nieużytkowane" filter="&quot;RODZAJ&quot;  =  'pozostałe grunty nieużytkowane' or  &quot;RODZAJ&quot;  =  'piarg, usypisko lub rumowisko skalne' or  &quot;RODZAJ&quot;  = 'teren kamienisty'  or  &quot;RODZAJ&quot;  =  'teren piaszczysty lub żwirowy'"/>
          <rule key="{2c0ae599-d3a2-4d7f-a0ae-5c1da88de561}" symbol="9" label="Uprawy trwałe" filter="&quot;RODZAJ&quot;  = 'ogródki działkowe' or  &quot;RODZAJ&quot;  =  'plantacja' or &quot;RODZAJ&quot;  =  'sad' or  &quot;RODZAJ&quot;  =  'szkółka roślin'"/>
          <rule key="{c1a17dc0-3604-4416-9e33-49e56a104c74}" symbol="10" label="Teren leśny i zadrzewiony" filter="&quot;RODZAJ&quot;  =  'las' or &quot;RODZAJ&quot;  =  'zagajnik' or  &quot;RODZAJ&quot;  =  'zadrzewienie'"/>
          <rule key="{3a0b42d5-fb51-401e-9efa-4b61705a6751}" symbol="11" label="Roślinność trawiasta lub krzewiasta" filter="&quot;RODZAJ&quot;  =  'kosodrzewina' or &quot;RODZAJ&quot;  =  'krzewy' or &quot;RODZAJ&quot;  =  'roślinność trawiasta'"/>
          <rule key="{8a5bba97-e6db-460e-8d45-b187c1f8cb89}" symbol="12" label="Uprawy na gruntach ornych" filter="&quot;RODZAJ&quot;  =  'uprawa na gruntach ornych' "/>
